generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  phone     String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Armada {
  id        String       @id @default(cuid())
  nama      String
  platNomor String       @unique
  tipe      String
  kapasitas Int
  foto      String?
  aktif     Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  status    ArmadaStatus @default(STANDBY)
  returnAt  DateTime?
  jadwals   Jadwal[]
}

model Jadwal {
  id            String         @id @default(cuid())
  tipe          TipePerjalanan
  rute          String
  asal          String
  tujuan        String
  bandara       String
  harga         Int
  jamBerangkat  String
  kapasitas     Int
  minKuota      Int            @default(1)
  terisi        Int            @default(0)
  estimasiWaktu Int
  aktif         Boolean        @default(true)
  armadaId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  hari          Hari           @default(SENIN)
  bookings      Booking[]
  armada        Armada?        @relation(fields: [armadaId], references: [id])
}

model Booking {
  id               String        @id @default(cuid())
  userId           String
  jadwalId         String
  jumlahKursi      Int           @default(1)
  totalHarga       Int
  status           BookingStatus @default(PENDING)
  tipeTrip         TipeTrip      @default(OPEN)
  tglBerangkat     String
  alamatJemput     String
  catatan          String?
  snapToken        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  metodePembayaran String?
  jadwal           Jadwal        @relation(fields: [jadwalId], references: [id])
  user             User          @relation(fields: [userId], references: [id])
  payment          Payment?
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String        @unique
  orderId   String        @unique
  amount    Int
  method    String?
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  booking   Booking       @relation(fields: [bookingId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum TipePerjalanan {
  ANTAR
  JEMPUT
}

enum TipeTrip {
  OPEN
  PRIVATE
}

enum BookingStatus {
  PENDING
  PAID
  MENUNGGU_KUOTA
  DIKONFIRMASI
  BERANGKAT
  SELESAI
  DIBATALKAN
  PENDING_PAYMENT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum Hari {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
  MINGGU
}

enum ArmadaStatus {
  STANDBY
  DALAM_PERJALANAN
  MAINTENANCE
  TIDAK_AKTIF
}
