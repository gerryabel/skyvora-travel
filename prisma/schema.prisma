generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// TRAVEL BOOKING DATABASE SCHEMA
// =============================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
  notificationLogs NotificationLog[]
}

model Armada {
  id        String      @id @default(cuid())
  nama      String
  platNomor String      @unique
  tipe      String      // "MPV", "SUV", "Minibus", dll
  kapasitas Int         // jumlah kursi penumpang
  foto      String?
  status    ArmadaStatus @default(STANDBY)
  aktif     Boolean     @default(true)
  returnAt  DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  jadwals Jadwal[]
}

model Jadwal {
  id             String    @id @default(cuid())
  tipe           TipePerjalanan // ANTAR atau JEMPUT
  rute           String
  asal           String
  tujuan         String
  bandara        String    // nama bandara
  hari           Hari      @default(SENIN) // hari jadwal (senin-minggu), tetap setiap minggu
  harga          Int       // harga per orang (dalam Rupiah)
  jamBerangkat   String    // format "HH:MM"
  kapasitas      Int       // total kursi
  minKuota       Int       @default(1) // minimum kursi terisi untuk berangkat
  terisi         Int       @default(0) // kursi yang sudah terisi
  estimasiWaktu  Int       // estimasi perjalanan dalam menit
  aktif          Boolean   @default(true)
  armadaId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  armada   Armada?  @relation(fields: [armadaId], references: [id])
  bookings Booking[]
}

model Booking {
  id               String        @id @default(cuid())
  userId           String
  jadwalId         String
  jumlahKursi      Int           @default(1)
  totalHarga       Int
  status           BookingStatus @default(PENDING)
  tipeTrip         TipeTrip      @default(OPEN)
  tglBerangkat     String        // format "YYYY-MM-DD"
  alamatJemput     String
  catatan          String?
  snapToken        String?       // token dari Midtrans
  metodePembayaran  String?       // "cash", "transfer", "ewallet"
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  jadwal  Jadwal   @relation(fields: [jadwalId], references: [id])
  payment Payment?
  notificationLogs NotificationLog[]
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String        @unique
  orderId   String        @unique // ID unik dari Midtrans
  amount    Int
  method    String?       // "gopay", "ovo", "va_bca", dll
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
}

// =============================================
// ENUMS
// =============================================

enum Role {
  USER
  ADMIN
}

enum TipePerjalanan {
  ANTAR  // Rumah -> Bandara
  JEMPUT // Bandara -> Rumah
}

enum TipeTrip {
  OPEN    // Shared / berbagi
  PRIVATE // Sewa penuh
}

enum BookingStatus {
  PENDING
  PAID
  MENUNGGU_KUOTA
  DIKONFIRMASI
  PENDING_PAYMENT
  BERANGKAT
  SELESAI
  DIBATALKAN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum Hari {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
  MINGGU
}

enum ArmadaStatus {
  STANDBY
  DALAM_PERJALANAN
  MAINTENANCE
  TIDAK_AKTIF
}

/* ============================================= */
/* NOTIFICATION LOG                               */
/* ============================================= */

model NotificationLog {
  id        String   @id @default(cuid())
  bookingId String?
  userId    String?
  email     String
  subject   String
  status    String   @default("PENDING") // PENDING, SENT, FAILED
  error     String?
  sentAt    DateTime?
  createdAt DateTime @default(now())

  booking   Booking? @relation(fields: [bookingId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}
